# Production Environment Configuration
# Copy to .env.production and fill in sensitive values

# ========== ENVIRONMENT ==========
NODE_ENV=production
VITE_API_BASE_URL=https://api.quantivis.io
VITE_APP_URL=https://quantivis.io

# ========== SUPABASE ==========
VITE_SUPABASE_URL=https://[PROJECT_ID].supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_SUPABASE_PROJECT_ID=[PROJECT_ID]
SUPABASE_DB_PASSWORD=[STRONG_PASSWORD_ROTATE_MONTHLY]

# ========== STRIPE ==========
VITE_STRIPE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ========== AUTHENTICATION ==========
# Must be rotated monthly
SESSION_SECRET=[GENERATE_NEW_SECRET]
JWT_SECRET=[GENERATE_NEW_SECRET]
ENCRYPTION_KEY=[GENERATE_NEW_SECRET]

# ========== MONITORING & OBSERVABILITY ==========
SENTRY_DSN=https://[key]@sentry.io/[project-id]
SENTRY_AUTH_TOKEN=[AUTH_TOKEN_FOR_RELEASES]
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_DEBUG=false

# LogRocket
LOGROCKET_ID=quantivis/quantivis

# DataDog (optional advanced monitoring)
DATADOG_API_KEY=[API_KEY]
DATADOG_SITE=datadoghq.com

# ========== SECURITY ==========
# CORS settings
CORS_ORIGIN=https://quantivis.io
CORS_CREDENTIALS=true

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Password requirements
MIN_PASSWORD_LENGTH=12
REQUIRE_UPPERCASE=true
REQUIRE_NUMBERS=true
REQUIRE_SPECIAL_CHARS=true

# ========== FEATURES ==========
# Feature flags
FEATURE_BOARD_REPORTS=true
FEATURE_BIAS_DETECTION=true
FEATURE_NATURAL_LANGUAGE_QUERY=true
FEATURE_PORTFOLIO_ANALYTICS=true

# ========== EMAIL ==========
# SendGrid or similar
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=[API_KEY]
EMAIL_FROM=noreply@quantivis.io
EMAIL_SUPPORT=support@quantivis.io

# ========== ENCRYPTION ==========
# For encrypting sensitive data at rest
ENCRYPTION_ALGORITHM=aes-256-gcm
ENCRYPTION_KEY_ROTATION_DAYS=90

# ========== AUDIT & COMPLIANCE ==========
# Audit log settings
AUDIT_LOG_RETENTION_DAYS=2555  # 7 years for compliance
AUDIT_LOG_ENCRYPTION=true

# GDPR compliance
DATA_DELETION_GRACE_PERIOD_DAYS=30
DATA_EXPORT_FORMAT=json

# ========== DATABASE ==========
# Connection pooling
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_QUERY_TIMEOUT_MS=30000

# Backup settings
BACKUP_SCHEDULE=daily
BACKUP_RETENTION_DAYS=90
BACKUP_ENCRYPTION=true

# ========== PERFORMANCE ==========
# Cache settings
CACHE_TTL_MINUTES=15
CACHE_MAX_SIZE_MB=500
CACHE_COMPRESSION=true

# CDN
CDN_URL=https://cdn.quantivis.io
CDN_CACHE_DAYS=365

# ========== LOGGING ==========
LOG_LEVEL=info
LOG_FORMAT=json
LOG_RETENTION_DAYS=30

# ========== MAINTENANCE ==========
# Maintenance mode
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE="System maintenance in progress"

# Health check
HEALTH_CHECK_INTERVAL_SECONDS=30
HEALTH_CHECK_TIMEOUT_SECONDS=5

# ========== DEPLOYMENT ==========
APP_VERSION=1.0.0
BUILD_DATE=2026-03-06
BUILD_COMMIT=[GIT_COMMIT_SHA]
BUILD_BRANCH=main

# ========== NOTIFICATIONS ==========
# Slack for alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_ALERT_CHANNEL=#quantivis-alerts

# PagerDuty for incidents
PAGERDUTY_INTEGRATION_KEY=[INTEGRATION_KEY]

# ========== TESTING IN PRODUCTION ==========
# Enable synthetic monitoring
SYNTHETIC_TESTS_ENABLED=true
SYNTHETIC_TESTS_INTERVAL_MINUTES=5

# ========== SUPABASE EDGE FUNCTIONS ==========
# CORS origins for Supabase functions (comma-separated)
ALLOWED_ORIGINS=https://quantivis.io,https://app.quantivis.io
# Default return URL for Stripe portal
DEFAULT_RETURN_URL=https://quantivis.io

# Tier limits for Supabase functions
TIER_STARTER_KPI_LIMIT=3
TIER_GROWTH_KPI_LIMIT=25
TIER_ENTERPRISE_KPI_LIMIT=999999
