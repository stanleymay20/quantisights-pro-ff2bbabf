# =============================================
# Quantivis System Configuration Reference
# All parameters have safe defaults — only set
# what you need to override.
# =============================================

# ========== SUPABASE (auto-configured) ==========
# VITE_SUPABASE_URL=
# VITE_SUPABASE_PUBLISHABLE_KEY=
# VITE_SUPABASE_PROJECT_ID=

# ========== COST OF DELAY INTELLIGENCE ==========
# Severity base scores (0-100)
VITE_COD_SEVERITY_CRITICAL=40
VITE_COD_SEVERITY_HIGH=28
VITE_COD_SEVERITY_MEDIUM=16
VITE_COD_SEVERITY_LOW=6

# Max contribution of confidence to score
VITE_COD_CONFIDENCE_MAX=20

# Age decay (score increases with unresolved age)
VITE_COD_AGE_DECAY_RATE=0.7
VITE_COD_AGE_DECAY_MAX=20

# Signal magnitude scaling
VITE_COD_SIGNAL_DELTA_MULT=0.5
VITE_COD_SIGNAL_DELTA_MAX=10

# Entity breadth scoring
VITE_COD_ENTITY_COUNT_MULT=1.5
VITE_COD_ENTITY_COUNT_MAX=5

# Bonus for accelerating trends
VITE_COD_TREND_ACCEL_BONUS=5

# Metric urgency multipliers (1.0 = neutral)
# SaaS / Subscription
VITE_COD_URGENCY_CHURN=1.3
VITE_COD_URGENCY_RETENTION=1.3
VITE_COD_URGENCY_REVENUE=1.2
VITE_COD_URGENCY_COST=1.1
VITE_COD_URGENCY_MARGIN=1.15
VITE_COD_URGENCY_GROWTH=1.05
# Industrial / Manufacturing
VITE_COD_URGENCY_SAFETY=1.5
VITE_COD_URGENCY_DOWNTIME=1.35
VITE_COD_URGENCY_YIELD=1.2
VITE_COD_URGENCY_THROUGHPUT=1.15
VITE_COD_URGENCY_DEFECT=1.25
# Regulatory / Compliance
VITE_COD_URGENCY_COMPLIANCE=1.4
VITE_COD_URGENCY_REGULATORY=1.4
VITE_COD_URGENCY_AUDIT=1.25
# Healthcare / Life Sciences
VITE_COD_URGENCY_PATIENT=1.45
VITE_COD_URGENCY_CLINICAL=1.3
VITE_COD_URGENCY_MORTALITY=1.5
VITE_COD_URGENCY_READMISSION=1.25
# Supply Chain / Logistics
VITE_COD_URGENCY_SUPPLY_CHAIN=1.3
VITE_COD_URGENCY_INVENTORY=1.15
VITE_COD_URGENCY_LOGISTICS=1.2
VITE_COD_URGENCY_PROCUREMENT=1.15
# Energy / Utilities
VITE_COD_URGENCY_ENERGY=1.25
VITE_COD_URGENCY_OUTAGE=1.4
VITE_COD_URGENCY_EMISSION=1.3
# Financial Services / Risk
VITE_COD_URGENCY_FRAUD=1.4
VITE_COD_URGENCY_EXPOSURE=1.3
VITE_COD_URGENCY_LIQUIDITY=1.35
VITE_COD_URGENCY_CREDIT=1.25
# Education / Public Sector
VITE_COD_URGENCY_ENROLLMENT=1.15
VITE_COD_URGENCY_ATTRITION=1.25
# Hospitality / Real Estate
VITE_COD_URGENCY_OCCUPANCY=1.2
VITE_COD_URGENCY_VACANCY=1.2

# Label classification thresholds (score 0-100)
VITE_COD_LABEL_CRITICAL=80
VITE_COD_LABEL_HIGH=55
VITE_COD_LABEL_MEDIUM=30

# Action window in days per label
VITE_COD_WINDOW_CRITICAL=3
VITE_COD_WINDOW_HIGH=7
VITE_COD_WINDOW_MEDIUM=14
VITE_COD_WINDOW_LOW=21

# ========== VALUE OF INFORMATION (VoI) ==========
VITE_VOI_UNCERTAINTY_REDUCTION=0.03
VITE_VOI_COST_PER_DATAPOINT=0.001
VITE_VOI_SAMPLE_INFO_RATIO=0.6
VITE_VOI_DECIDE_NOW_CONF=0.75

# ========== REGRET MINIMIZATION ==========
VITE_REGRET_P10_FALLBACK=0.3
VITE_REGRET_P90_FALLBACK=1.5

# ========== DECISION VELOCITY ==========
VITE_VELOCITY_IMPROVING=0.85
VITE_VELOCITY_DEGRADING=1.15
VITE_VELOCITY_SLOW_WARN_DAYS=5
VITE_VELOCITY_MIN_DECISIONS=4

# ========== PORTFOLIO RISK ==========
# Z-score for VaR (1.645 = 95%, 2.326 = 99%)
VITE_PORTFOLIO_VAR_CONF=1.645
VITE_PORTFOLIO_HIGH_CORR=0.5
VITE_PORTFOLIO_HIGH_CONC=60

# ========== CONVERGENCE ANALYSIS ==========
VITE_CONV_VOL_DIV_THRESHOLD=35
VITE_CONV_VOL_DIV_PENALTY=10
VITE_CONV_ALIGNED=80
VITE_CONV_TENSION=60
VITE_CONV_MISALIGNMENT=40

# Conflict detection rules
VITE_CONV_CEO_CFO_DIV=30
VITE_CONV_CEO_CFO_PENALTY=15
VITE_CONV_CMO_LOW=40
VITE_CONV_COO_HIGH=70
VITE_CONV_GROWTH_EXEC_PENALTY=8
VITE_CONV_CFO_HIGH=75
VITE_CONV_CEO_LOW=50
VITE_CONV_CASH_EXP_PENALTY=15
VITE_CONV_VOL_HIGH=80
VITE_CONV_VOL_LOW=40
VITE_CONV_OP_IMBAL_PENALTY=25

# Reconcile interval (ms, default 6 hours)
VITE_CONV_RECONCILE_INTERVAL=21600000
